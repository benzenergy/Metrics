<Window
    x:Class="ver10.MainWindow"
    KeyDown="Window_KeyDown"
    xmlns:local="clr-namespace:ver10"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:modern="clr-namespace:ModernCalendarLib;assembly=ModernCalendarLib"
    Title="UNI Convert"
    Height="593"
    Width="800"
    Loaded="Window_Loaded"
    WindowStyle="None"
    ResizeMode="CanMinimize"
    Background="#202020"
    WindowStartupLocation="CenterScreen"
    MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="ApplicationCommands.Save"/>
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="ApplicationCommands.SaveAs"/>
    </Window.InputBindings>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resource/Styles.xaml"/>

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1B1B1B">
            <Grid>
                <Image Source="/Resource/header.png"
                       Height="25"
                       Width="Auto"
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"
                       HorizontalAlignment="Left"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Width="35"
                            Height="35"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="BtnMinimize_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid x:Name="grid"
                                          Background="#01000000">

                                    <Image Source="/Resource/tray.png"
                                               Width="12"
                                               Height="12"
                                               Stretch="Uniform"/>
                                </Grid>
                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver"
                                                 Value="True">

                                        <Setter TargetName="grid"
                                                    Property="Background"
                                                    Value="#333333"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed"
                                                 Value="True">

                                        <Setter TargetName="grid"
                                                    Property="Background"
                                                    Value="#555555"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled"
                                                 Value="False">

                                        <Setter TargetName="grid"
                                                    Property="Background"
                                                    Value="#222222"/>

                                        <Setter Property="Opacity"
                                                    Value="0.5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Width="35"
                            Height="35"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="BtnClose_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid x:Name="grid"
                                          Background="#01000000">

                                    <Image Source="/Resource/close.png"
                                               Width="12"
                                               Height="12"
                                               Stretch="Uniform"/>
                                </Grid>
                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver"
                                                 Value="True">

                                        <Setter TargetName="grid"
                                                    Property="Background"
                                                    Value="#333333"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed"
                                                 Value="True">

                                        <Setter TargetName="grid"
                                                    Property="Background"
                                                    Value="#555555"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled"
                                                 Value="False">

                                        <Setter TargetName="grid"
                                                    Property="Background"
                                                    Value="#222222"/>

                                        <Setter Property="Opacity"
                                                    Value="0.5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
              Margin="0"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0">

                    <TextBlock Text="Стоимость чека"
                               Foreground="#8F8F8F"
                               FontSize="14"
                               Margin="15,10,0,0"
                               FontFamily="/Assets/Fonts/#Inter"
                               FontWeight="Regular"/>

                    <Grid>
                        <TextBox x:Name="CheckPriceBox"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 PreviewTextInput="NumberValidation"
                                 Foreground="#D2D2D2"
                                 VerticalContentAlignment="Center"
                                 Height="40"
                                 Width="250"/>

                        <TextBlock Text="Введите цену"
                                   Margin="20,0,0,0"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Foreground="LightGray"
                                   IsHitTestVisible="False">
                            
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=CheckPriceBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>



                    <TextBlock Text="Стоимость аренды"
                               Foreground="#8F8F8F"
                               FontSize="14"
                               Margin="15,10,0,0"
                               FontFamily="/Assets/Fonts/#Inter"
                               FontWeight="Regular"/>

                    <TextBox x:Name="RentPriceBox"
                             Style="{StaticResource InputTextBoxStyle}"
                             PreviewTextInput="NumberValidation"
                             HorizontalAlignment="Left"
                             VerticalContentAlignment="Center"
                             Foreground="#D2D2D2"
                             Margin="15,10,0,0"
                             Height="40"
                             Width="250"
                             MaxLength="10"/>

                    <TextBlock Text="Количество дней"
                               Foreground="#8F8F8F"
                               FontSize="14"
                               Margin="15,10,0,0"
                               FontFamily="/Assets/Fonts/#Inter"
                               FontWeight="Regular"/>

                    <TextBox x:Name="DaysBox"
                             Style="{StaticResource InputTextBoxStyle}"
                             PreviewTextInput="NumberValidation"
                             HorizontalAlignment="Left"
                             VerticalContentAlignment="Center"
                             Foreground="#D2D2D2"
                             FontFamily="/Assets/Fonts/#Inter"
                             FontWeight="Regular"
                             Margin="15,10,0,0"
                             Height="40"
                             Width="250"                           
                             MaxLength="10"/>

                    <TextBlock Text="Суточные"
                               Foreground="#8F8F8F"
                               FontSize="14"
                               Margin="15,10,0,0"
                               FontFamily="/Assets/Fonts/#Inter"/>

                    <TextBox x:Name="DailyBox"
                             Style="{StaticResource InputTextBoxStyle}"
                             PreviewTextInput="NumberValidation"
                             HorizontalAlignment="Left"
                             VerticalContentAlignment="Center"
                             Foreground="#D2D2D2"
                             FontFamily="/Assets/Fonts/#Inter"
                             FontWeight="Regular"
                             Margin="15,10,0,0"
                             Height="40"
                             Width="250"
                             MaxLength="10"/>

                    <TextBlock Text="Процент"
                               Foreground="#8F8F8F"
                               FontSize="14"
                               Margin="15,10,0,0"
                               FontFamily="/Assets/Fonts/#Inter"/>

                    <TextBox x:Name="PercentBox"
                             Style="{StaticResource InputTextBoxStyle}"
                             PreviewTextInput="NumberValidation"
                             HorizontalAlignment="Left"
                             VerticalContentAlignment="Center"
                             Foreground="#D2D2D2"
                             FontFamily="/Assets/Fonts/#Inter"
                             FontWeight="Regular"
                             Margin="15,10,0,0"
                             Height="40"
                             Width="250"
                             MaxLength="10"/>

                    <TextBlock Text="Доп. расходы"
                               Foreground="#8F8F8F"
                               FontSize="14"
                               Margin="15,10,0,0"
                               FontFamily="/Assets/Fonts/#Inter"
                               FontWeight="Regular"/>

                    <TextBox x:Name="ExtraBox"
                             Style="{StaticResource InputTextBoxStyle}"
                             PreviewTextInput="NumberValidation"
                             HorizontalAlignment="Left"
                             VerticalContentAlignment="Center"
                             Foreground="#D2D2D2"
                             FontFamily="/Assets/Fonts/#Inter"
                             FontWeight="Regular"
                             Margin="15,9,0,0"
                             Height="40"
                             Width="250"
                             MaxLength="10"/>

                </StackPanel>

                <Border Grid.Column="1"
                        Grid.Row="0"
                        Margin="10, 37, 0, 0"
                        Background="#202020"
                        BorderBrush="#535353"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Height="423"
                        Width="250"
                        CornerRadius="5">

                    <TextBlock x:Name="OutputText"
                               Margin="10, 10, 10, 10"
                               TextWrapping="Wrap"
                               Foreground="#D2D2D2"
                               FontSize="15"
                               FontFamily="/Assets/Fonts/#Inter"
                               IsHitTestVisible="False"/>

                </Border>

                <StackPanel Grid.Column="2"
                            Grid.Row="0"
                            Margin="10, 32, 30, 0"
                            x:Name="CalendarContainer">

                    <local:CustomCalendar x:Name="CalendarPrev"
                                          Margin="0, 5, 0, 1"/>
                    <local:CustomCalendar x:Name="CalendarCurrent"
                                          Margin="0, 9, 0, 8"/>
                    <local:CustomCalendar x:Name="CalendarNext"/>
                </StackPanel>

                <Grid Grid.Row="1"
                      Grid.ColumnSpan="3"
                      Margin="0,0,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"

                            Background="#242424"
                            BorderBrush="#535353"
                            BorderThickness="1"
                            CornerRadius="5"
                            Width="250"
                            Height="40"
                            Padding="8"
                            Margin="15, 10, 0, 0">

                        <TextBlock VerticalAlignment="Center"
                                   FontFamily="/Assets/Fonts/#Inter"
                                   FontSize="14">

                                <Run Text="Процент от "
                                     Foreground="#8F8F8F"
                                     FontFamily="/Assets/Fonts/#Inter"
                                     FontWeight="Regular"
                                     FontSize="14"/>

                                <Run x:Name="PercentMethodText"
                                     Text="от общей суммы"
                                     FontFamily="/Assets/Fonts/#Inter"
                                     FontWeight="Regular"
                                     FontSize="14">

                                <Run.Foreground>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop Color="#35E5CC" Offset="0"/>
                                        <GradientStop Color="#4098CE" Offset="0.5"/>
                                        <GradientStop Color="#4D3FD1" Offset="1"/>
                                    </LinearGradientBrush>
                                </Run.Foreground>

                            </Run>

                        </TextBlock>
                    </Border>

                    <Button Grid.Column="1"
                            x:Name="CalculateButton"
                            Content="Рассчитать"
                            FontSize="16px"
                            FontFamily="/Assets/Fonts/#Inter"
                            FontWeight="SemiBold"
                            Style="{StaticResource CalculateButtonStyle}"
                            Width="250"
                            Height="40"
                            Padding="8"
                            Margin="10, 10, 0, 0"
                            VerticalContentAlignment="Center"
                            HorizontalAlignment="Center"
                            Click="BtnCalculate_Click">

                        <Button.Foreground>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#35E5CC" Offset="0"/>
                                <GradientStop Color="#4098CE" Offset="0.5"/>
                                <GradientStop Color="#4D3FD1" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Foreground>
                    </Button>

                    <Button Grid.Column="2"
                            x:Name="BtnSettings"
                            Style="{StaticResource SettingsButtonStyle}"
                            Content="Настройки"
                            FontSize="16px"
                            FontFamily="/Assets/Fonts/#Inter"
                            FontWeight="SemiBold"
                             HorizontalAlignment="Left"
                             Height="40"
                             Width="250"
                            Margin="10, 10, 0, 0"
                            Click="BtnSettings_Click"/>
                </Grid>
            </Grid>
        </ScrollViewer>

        <DockPanel Grid.Row="3" Margin="0, 15, 0, 0"
                   Background="#1B1B1B"
                   LastChildFill="False"
                   Height="33">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="10,0">

                <Button x:Name="FileButton"
                        Style="{StaticResource TextButtonStyle}"
                        Content="Файл"
                        FontSize="12"
                        Margin="10, 0, 20, 0"
                        Click="FileButton_Click"/>

                <Button Content="Справка"
                        FontSize="12"
                        Margin="0, 0, 0, 0"
                        Style="{StaticResource TextButtonStyle}"
                        Click="AboutButton_Click"/>

                <Popup x:Name="FilePopup"
                   Placement="Top"
                   PlacementTarget="{Binding ElementName=FileButton}"
                   StaysOpen="False"
                   AllowsTransparency="True">

                    <Border Background="#101010"
                        BorderBrush="#3C3C3C"
                        BorderThickness="1"
                        CornerRadius="0"
                        Padding="5">

                        <StackPanel Width="320"
                                    Height="Auto">

                            <Button Style="{StaticResource PopupMenuButtonStyle}"
                                    Click="SaveAsExcel_Click">
                                
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Assets/Icons/excel.png"
                                       Width="24"
                                       Height="Auto"
                                       Margin="0,0,10,0"/>

                                    <TextBlock Text="Сохранить как Excel"
                                           FontSize="14px"/>

                                    <TextBlock Text="Ctrl+S"
                                           Foreground="#888888"
                                           FontSize="14px"
                                           VerticalAlignment="Center"
                                           Margin="30,0,0,0"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Popup>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>